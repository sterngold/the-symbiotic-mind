{
  "name": "the-symbiotic-mind",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI × HI — The Symbiotic Mind. Static site built with Eleventy.",
  "scripts": {
    "build": "eleventy && npm run pagefind",
    "build:no-search": "eleventy",
    "serve": "eleventy --serve --port=8080",
    "clean": "rm -rf _site",
    "pagefind": "pagefind --site _site --output-subdir pagefind"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "luxon": "^3.5.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0",
    "pagefind": "^1.1.1"
  }
}
