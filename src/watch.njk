<div class="about-header">
  <h1>Watch</h1>
  <p class="about-sub">Video conversations and field notes. The visual track of the same recordings that become the podcast.</p>
</div>

<div class="about-body">
  <p>Find every video on <a href="{{ podcast.show.youtubeChannelUrl }}">YouTube — @symbiotic-mind</a>. The channel is organised in four playlists:</p>
  <ul>
    <li><strong>Field Notes</strong> — short 3–8 min essays-on-camera tied to a post.</li>
    <li><strong>Conversations</strong> — long-form dialogues between Vlad and Milena.</li>
    <li><strong>Built with AI</strong> — Vlad's dev workflow with Claude Code, multi-model setups, Ollama.</li>
    <li><strong>Research Reads</strong> — walking through a paper or a finding that changed our thinking.</li>
  </ul>

  <p>If you'd rather subscribe by feed: <a href="https://www.youtube.com/feeds/videos.xml?channel_id={{ podcast.show.youtubeChannelId }}">YouTube channel RSS</a>.</p>
</div>

{# Video retells: any post carrying a youtubeId. These are AI-made companions to
   the essays — not podcast episodes (those live in podcast.episodes[] and feed
   the audio RSS). Auto-listed, newest first, so new posts appear here for free. #}
{% set retellPosts = [] %}
{% for p in collections.posts %}
  {% if p.data.youtubeId %}{% set retellPosts = (retellPosts.push(p), retellPosts) %}{% endif %}
{% endfor %}
{% if retellPosts.length %}
<p class="section-label">Essays, retold on video</p>
<ul class="post-list">
{% for p in retellPosts %}
  <li>
    <div class="post-meta">{{ p.date | postDate }} &middot; {{ authors[p.data.author].name }}</div>
    <h2><a href="{{ p.url }}">{{ p.data.title }}</a></h2>
    <div class="video-retell-frame" style="margin-top:0.75rem;">
      <iframe src="https://www.youtube-nocookie.com/embed/{{ p.data.youtubeId }}"
              loading="lazy" allow="fullscreen" allowfullscreen
              title="{{ p.data.title }}"></iframe>
    </div>
  </li>
{% endfor %}
</ul>
{% endif %}

{% if podcast.episodes.length %}
<p class="section-label">Recent episodes</p>
<ul class="post-list">
{% for ep in podcast.episodes %}
  {% if ep.youtubeId %}
  <li>
    <div class="post-meta">{{ ep.pubDate | postDate }} &middot; Episode {{ ep.number }}</div>
    <h2><a href="/episodes/{{ ep.slug }}/">{{ ep.title }}</a></h2>
    <div class="video-retell-frame" style="margin-top:0.75rem;">
      <iframe src="https://www.youtube-nocookie.com/embed/{{ ep.youtubeId }}"
              loading="lazy" allow="fullscreen" allowfullscreen
              title="{{ ep.title }}"></iframe>
    </div>
  </li>
  {% endif %}
{% endfor %}
</ul>
{% endif %}

