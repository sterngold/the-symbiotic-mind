---
layout: layouts/base.njk
ogType: article
---
{% set authorObj = authors[author] %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "image": [{{ (ogImage or site.defaultOgImage) | absUrl(site.url) | dump | safe }}],
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ (updated or date) | isoDate }}",
  "author": [{
    "@type": "Person",
    "name": {{ authorObj.name | dump | safe }},
    "url": {{ authorObj.url | dump | safe }}
  }],
  "publisher": { "@id": "{{ site.url }}/#organization" },
  "isPartOf": { "@id": "{{ site.url }}/#website" },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ page.url | absUrl(site.url) }}"
  }
}
</script>
{% set crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Writing', url: '/posts/' },
  { name: title, url: page.url }
] %}
{% include "partials/breadcrumbs.njk" %}
{% endblock %}

<article>
  <div class="reading-progress" aria-hidden="true"></div>

  <header class="post-header">
    {% if kicker %}<p class="post-kicker">{{ kicker }}</p>{% endif %}
    <h1>{{ title }}</h1>
    {% if deck %}<p class="post-deck">{{ deck }}</p>{% endif %}
    <p class="post-byline">
      <span class="byline-author"><a href="/authors/{{ authorObj.slug }}/">{{ authorObj.name }}</a></span>
      <span class="byline-sep">&middot;</span>
      <time datetime="{{ date | isoDate }}">{{ date | postDate }}</time>
      <span class="byline-sep">&middot;</span>
      <span class="byline-reading">{{ content | readingTime }} read</span>
    </p>
  </header>

  {% if cover %}
  <figure class="post-cover">
    <img src="{{ cover.src }}" alt="{{ cover.alt }}">
  </figure>
  {% endif %}

  <div class="post-body{% if dropCap === false %} no-dropcap{% endif %}">
    {{ content | safe }}
  </div>

  {# Video retell: live YouTube embed, Canva fallback, or a "coming soon"
     placeholder when the post opts in with `videoPending: true`. #}
  {% if youtubeId or videoRetell %}
  <aside class="video-retell">
    <p class="video-retell-caption">Prefer this in video format? Here is how an AI member of the team turned this article into a video story.</p>
    <div class="video-retell-frame">
      {% if youtubeId %}
      <iframe
        src="https://www.youtube-nocookie.com/embed/{{ youtubeId }}"
        loading="lazy"
        allow="fullscreen"
        allowfullscreen
        title="Video retell — {{ title }}"></iframe>
      {% else %}
      <iframe
        src="{{ videoRetell.url }}"
        loading="lazy"
        allow="fullscreen"
        allowfullscreen
        title="Video retell — {{ title }}"></iframe>
      {% endif %}
    </div>
  </aside>
  {% elif videoPending %}
  <aside class="video-retell video-retell-pending">
    <p class="video-retell-caption">Video retell coming soon — an AI member of the team will turn this article into a video story.</p>
    <div class="video-retell-frame video-retell-frame-pending" role="img" aria-label="Video retell coming soon">
      <span class="video-retell-pending-label">🎥 Coming soon</span>
    </div>
  </aside>
  {% endif %}

  <footer class="post-credit">
    <p><strong>Vlad Sterngold</strong> is an AI practitioner and builder based in Amsterdam. <strong>Milena S. Nikolova, PhD</strong> is a behavioral scientist and founder of BehaviorSMART based in Lausanne. This post is part of <em>AI × HI — The Symbiotic Mind</em>, their discovery journey on human-AI symbiosis.</p>
  </footer>

  {% if tags and tags.length %}
  <p class="post-tags">
    {% for t in tags %}{% if t != "post" %}<a href="/tags/{{ t }}/" class="post-tag">#{{ t }}</a> {% endif %}{% endfor %}
  </p>
  {% endif %}

  {# Related essays: curated per-post via `related` frontmatter (list of file slugs) —
     the topic-cluster internal-link mesh. Falls back to the simple read-next
     (most recent other post) when no `related` list is set. #}
  {% if related and related.length %}
  <aside class="read-next">
    <p class="section-label">Related essays</p>
    {% for slug in related %}
      {% for p in collections.posts %}
        {% if p.fileSlug == slug %}
        <div class="related-item">
          <div class="post-meta">{{ p.date | postDate }} &middot; {{ authors[p.data.author].name }}</div>
          <h3><a href="{{ p.url }}">{{ p.data.title }}</a></h3>
        </div>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </aside>
  {% else %}
  {% set otherPosts = [] %}
  {% for p in collections.posts %}
    {% if p.url != page.url %}{% set otherPosts = (otherPosts.push(p), otherPosts) %}{% endif %}
  {% endfor %}
  {% if otherPosts.length %}
  {% set next = otherPosts[0] %}
  <aside class="read-next">
    <p class="section-label">Read next</p>
    <div class="post-meta">{{ next.date | postDate }} &middot; {{ authors[next.data.author].name }}</div>
    <h3><a href="{{ next.url }}">{{ next.data.title }}</a></h3>
    {% if next.data.description %}<p class="post-excerpt">{{ next.data.description }}</p>{% endif %}
  </aside>
  {% endif %}
  {% endif %}

</article>

{% include "partials/newsletter.njk" %}

{% include "partials/giscus.njk" %}
