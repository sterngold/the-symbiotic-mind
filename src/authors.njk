---
pagination:
  data: authors
  size: 1
  alias: author
  resolve: values
permalink: "/authors/{{ author.slug }}/index.html"
eleventyComputed:
  title: "{{ author.name }}"
  description: "Writing by {{ author.name }} on The Symbiotic Mind — {{ author.role }}, {{ author.location }}."
  ogImage: "/images/og/author-{{ author.slug }}.png"
layout: layouts/base.njk
---

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "@id": {{ author.personId | dump | safe }},
    "name": {{ author.name | dump | safe }}{% if author.honorific %},
    "honorificSuffix": {{ author.honorific | dump | safe }}{% endif %},
    "jobTitle": {{ author.role | dump | safe }},
    "description": {{ author.bio | dump | safe }},
    "url": {{ author.url | dump | safe }},
    "homeLocation": {
      "@type": "Place",
      "name": {{ author.location | dump | safe }}
    },
    "sameAs": [
      {% for s in author.sameAs %}{{ s | dump | safe }}{% if not loop.last %},{% endif %}{% endfor %}
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "The Symbiotic Mind",
      "url": "{{ site.url }}"
    }
  }
}
</script>
{% set crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Authors', url: '/authors/' },
  { name: author.name, url: page.url }
] %}
{% include "partials/breadcrumbs.njk" %}
{% endblock %}

<div class="about-header">
  <h1>{{ author.name }}</h1>
  <p class="about-sub">{{ author.role }} &middot; {{ author.location }}</p>
</div>

<div class="about-body">
  <p>{{ author.bio }}</p>
  <p>
    <a href="{{ author.url }}">{{ author.url }}</a>
    &middot; <a href="/feed/{{ author.slug }}.xml">RSS for {{ author.name }}</a>
  </p>
</div>

<p class="section-label">Writing by {{ author.name }}</p>
<ul class="post-list">
{% for post in collections.posts %}
  {% if post.data.author == author.slug %}
  <li>
    <div class="post-meta">{{ post.date | postDate }}</div>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}<p class="post-excerpt">{{ post.data.description }}</p>{% endif %}
  </li>
  {% endif %}
{% endfor %}
</ul>
