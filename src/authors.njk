---
pagination:
  data: authors
  size: 1
  alias: author
  resolve: values
permalink: "/authors/{{ author.slug }}/index.html"
eleventyComputed:
  title: "{{ author.name }}"
  description: "Writing by {{ author.name }} on The Symbiotic Mind."
layout: layouts/base.njk
---

<div class="about-header">
  <h1>{{ author.name }}</h1>
  <p class="about-sub">{{ author.role }} &middot; {{ author.location }}</p>
</div>

<div class="about-body">
  <p>{{ author.bio }}</p>
  <p><a href="{{ author.url }}">{{ author.url }}</a> &middot; <a href="/feed/{{ author.slug }}.xml">RSS for {{ author.name }}</a></p>
</div>

<p class="section-label">Writing by {{ author.name }}</p>
<ul class="post-list">
{% for post in collections.posts %}
  {% if post.data.author == author.slug %}
  <li>
    <div class="post-meta">{{ post.date | postDate }}</div>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}<p class="post-excerpt">{{ post.data.description }}</p>{% endif %}
  </li>
  {% endif %}
{% endfor %}
</ul>
