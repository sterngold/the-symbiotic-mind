---
pagination:
  data: collections.tags
  size: 1
  alias: tag
permalink: "/tags/{{ tag }}/index.html"
eleventyComputed:
  title: "#{{ tag }}"
  description: "Posts tagged #{{ tag }} on The Symbiotic Mind."
layout: layouts/base.njk
---

<div class="posts-header">
  <h1>#{{ tag }}</h1>
</div>

<ul class="post-list">
{% for post in collections.posts %}
  {% if post.data.tags and (tag in post.data.tags) %}
  <li>
    <div class="post-meta">{{ post.date | postDate }} &middot; {{ authors[post.data.author].name }}</div>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    {% if post.data.description %}<p class="post-excerpt">{{ post.data.description }}</p>{% endif %}
  </li>
  {% endif %}
{% endfor %}
</ul>
